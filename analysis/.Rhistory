# Library loading
library(data.table)
library(dplyr)
exon_coord_tbl <- fread('~/OneDrive - CRG - Centre de Regulacio Genomica/papers/OpenSplice_paper/libraries_design/02_mutagenesis_libraries/output/genomic_coord_mut.tsv',sep='\t')
exon_coord_tbl <- exon_coord_tbl %>%
filter(!grepl('del',identifier)) %>%
select(exon,start,CHROM,POS) %>%
rename(chrom = CHROM,
hg38_pos = POS) %>%
distinct()
annotated_summary <- fread('~/Desktop/OpenSplice/results/sre_mapping/annotated_summary.txt',sep='\t')
annotated_summary_merge <- merge(annotated_summary, exon_coord_tbl,by.x= c('exon_id','start'),by.y= c('exon','start'))
annotated_summary = annotated_summary_merge  %>%
mutate(region = case_when(
start <= 66 ~ 'Intron up',
start >= 67 & start <=71 ~ "3'SS",
start >= 72 & start <= (exon_length+67) ~ 'Exon',
start >= (exon_length+68) & start <= (exon_length+76) ~ "5'SS",
start > (exon_length+76) ~ 'Intron down'
),
split_iup = case_when(
start <= 26 ~ 'Distal (1-26nt)',
start >= 44 & start <= 50 ~ 'BP (27-51nt)',
start >= 51 & start <= 66 ~ 'PPT (52-66nt)',
TRUE ~ NA))
sre_df <- annotated_summary %>%
arrange(exon_id, region, start) %>%
group_by(exon_id, wt_psi, exon_length, region,chrom) %>%
mutate(
wt_psi = round(wt_psi,1),
sre_id = cumsum(
row_number() == 1 | type_annotation != lag(type_annotation, default = first(type_annotation))
),
sre_type = case_when(
type_annotation =='E' ~ 'Enhancer',
type_annotation =='O' ~ 'Overlap',
type_annotation =='S' ~ 'Silencer',
type_annotation =='N' ~ 'Neutral'
)
) %>%
group_by(exon_id, wt_psi, exon_length, region, sre_id,sre_type, type_annotation,chrom) %>%
summarise(
start_sre = min(start),
end_sre   = max(start),
hg38_start_sre = min(hg38_pos),
hg38_start_end = max(hg38_pos),
sre_length = end_sre - start_sre + 1,
.groups = "drop"
) %>%
select(exon_id, wt_psi, exon_length, region, start_sre, end_sre, sre_length, sre_type, type_annotation,chrom,hg38_start_sre,hg38_start_end)
fwrite(sre_df, '~/Desktop/OpenSplice/results/supplementary_tables/Supplementary_Table7_final.tsv',sep='\t')
old = fread('~/Desktop/OpenSplice/results/supplementary_tables/Supplementary_Table7.tsv',sep='\t')
identical(old,sre_df)
View(old)
View(sre_df)
View(old)
diff_df =setdiff(old,sre_df)
rlang::last_trace()
identical(old %>% select(-hg38_start_sre,-hg38_start_end),sre_df  %>% select(-hg38_start_sre,-hg38_start_end))
diff = setdiff(old %>% select(-hg38_start_sre,-hg38_start_end),sre_df  %>% select(-hg38_start_sre,-hg38_start_end))
